---
import Layout from "@layouts/Layout.astro"
import "../styles/global.css"
import FormattedDate from "@components/FormattedDate.astro"
import { getCollection } from "astro:content"
import { Icon } from "astro-icon/components"

// Query content collections and sort posts by date (descending)
const sortedPosts = (await getCollection("blog")).sort((a, b) => {
  const dateA = new Date(a.data.date).valueOf()
  const dateB = new Date(b.data.date).valueOf()
  return dateB - dateA
})

// Marketplace items
const allItems = await getCollection("items")
const availableCount = allItems.filter((i) => !i.data.sold).length
---

<Layout home>
  <section class="mb-8">
    <div class="flex gap-3 items-center mt-4 justify-center">
      <a
        href="https://instagram.com/cgy7777"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Instagram"
      >
        <Icon name="simple-icons:instagram" class="w-6 h-6" />
      </a>
      <a
        href="https://github.com/cgyinthehouse"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub"
      >
        <Icon name="simple-icons:github" class="w-6 h-6" />
      </a>
      <a
        href="https://threads.com/cgy7777"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Threads"
      >
        <Icon name="simple-icons:threads" class="w-6 h-6" />
      </a>
    </div>
    <p class="my-6 text-slate-800 font-medium leading-relaxed">
      Full Stack Developer | Web3 Enthusiast | Runner | Music Lover
    </p>
  </section>
  <section class="text-xl pt-px">
    <h2 class="text-2xl mt-4">Blog</h2>
    <ul class="list-none p-0 m-0">
      {
        sortedPosts.map((post) => (
          <li class="my-0 mx-5">
            <a href={`/blog/${post.id}`}>{post.data.title}</a>
            <br />
            <small class="text-slate-600">
              <FormattedDate dateString={post.data.date} />
            </small>
          </li>
        ))
      }
    </ul>
  </section>
  <section class="text-xl pt-px">
    <h2 class="text-2xl mt-4">Marketplace</h2>
    <a
      href="/sell"
      id="sell-entry-link"
      class="group block no-underline!"
    >
      <div
        id="sell-entry-card"
        class="mt-3 py-5 px-6 rounded-xl bg-[linear-gradient(135deg,#1a1a2e_0%,#16213e_50%,#0f3460_100%)] border border-violet-500/30 flex items-center justify-between gap-4 transition-all duration-200 text-inherit group-hover:-translate-y-0.5 group-hover:shadow-lg group-hover:shadow-violet-500/25 group-hover:border-violet-500/60"
      >
        <div>
          <p class="text-base font-bold text-[#e2e8f0] mb-[0.3rem]">
            🛍️ My Marketplace
          </p>
          <p class="text-[0.85rem] text-[#94a3b8]">
            {availableCount} item{availableCount !== 1 ? "s" : ""} available · Browse
            used goods for sale
          </p>
        </div>
        <span class="text-2xl shrink-0">→</span>
      </div>
    </a>
  </section>
</Layout>
