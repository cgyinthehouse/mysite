---
---
<section class="relative overflow-hidden pt-12 px-[1.2rem] pb-10 sm:pt-20 sm:px-8 sm:pb-16 text-center">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_60%_at_50%_0%,rgba(139,92,246,0.25)_0%,transparent_70%)] pointer-events-none"></div>

  <div class="relative">
    <div class="inline-flex items-center gap-[0.4rem] bg-violet-500/15 border border-violet-500/35 rounded-full px-4 py-[0.35rem] text-xs font-semibold text-violet-300 tracking-[0.05em] uppercase mb-6">
      ✨ Handpicked Items
    </div>

    <h1 class="text-[clamp(2.5rem,6vw,4rem)] font-extrabold leading-[1.1] mb-5 bg-gradient-to-br from-white to-violet-300 bg-clip-text text-transparent">
      Kent's Marketplace
    </h1>

    <p class="text-[1.1rem] text-[#8b8aa6] max-w-[480px] mx-auto mb-10">
      Quality used items, fairly priced. Everything listed is tested, clean, and ready to go.
    </p>

    <div class="max-w-[600px] mx-auto rounded-[16px] overflow-hidden shadow-[0_24px_80px_rgba(0,0,0,0.6),0_0_0_1px_rgba(255,255,255,0.08)] relative">
      <img
        src="/images/sell-hero.png"
        alt="Flat lay of used items for sale including camera, headphones, wallet, and watch"
        class="w-full h-80 object-cover block"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-[rgba(15,15,19,0.8)] to-transparent"></div>
      <div class="absolute bottom-6 left-0 right-0 flex justify-center gap-8 px-6">
        <div class="text-center">
          <div class="text-2xl font-extrabold text-white" id="hero-available-count">—</div>
          <div class="text-[0.75rem] text-white/70 uppercase tracking-[0.05em]">Available</div>
        </div>
        <div class="text-center">
          <div class="text-2xl font-extrabold text-white" id="hero-category-count">—</div>
          <div class="text-[0.75rem] text-white/70 uppercase tracking-[0.05em]">Categories</div>
        </div>
        <div class="text-center">
          <div class="text-2xl font-extrabold text-white" id="hero-avg-price">—</div>
          <div class="text-[0.75rem] text-white/70 uppercase tracking-[0.05em]">Avg. Price</div>
        </div>
      </div>
    </div>
  </div>
</section>
