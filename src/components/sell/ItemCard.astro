---
interface Props {
  item: {
    id: string;
    name: string;
    category: string;
    condition: string;
    price: number;
    description: string;
    tags: string[];
    emoji: string;
    sold: boolean;
  };
  conditionColors: Record<string, string>;
}
const { item, conditionColors } = Astro.props;
---
<article
  class={`item-card bg-[#242433] border border-white/[0.08] rounded-[16px] overflow-hidden transition-[transform,box-shadow,border-color] duration-[250ms] relative cursor-pointer hover:-translate-y-1 hover:shadow-[0_20px_60px_rgba(139,92,246,0.2)] hover:border-violet-500/40 ${item.sold ? 'sold opacity-60 pointer-events-none' : ''}`}
  data-category={item.category}
  data-name={item.name.toLowerCase()}
  data-tags={item.tags.join(' ')}
  data-id={item.id}
  id={`item-card-${item.id}`}
>
  {item.sold && (
    <span class="absolute top-4 right-4 bg-black/75 text-white text-[0.7rem] font-bold uppercase tracking-[0.08em] px-3 py-1 rounded-full z-[2]">
      SOLD
    </span>
  )}

  <!-- Emoji banner -->
  <div class="h-[140px] bg-gradient-to-br from-[#17171e] to-[#1f1f2a] flex items-center justify-center text-[4rem] relative">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_60%,rgba(139,92,246,0.12),transparent_70%)]"></div>
    <span role="img" aria-label={item.name} class="relative">{item.emoji}</span>
  </div>

  <!-- Card body -->
  <div class="p-5">
    <div class="flex items-center justify-between mb-[0.6rem]">
      <span class="text-[0.72rem] font-semibold uppercase tracking-[0.06em] text-violet-300">{item.category}</span>
      <span
        class="text-[0.72rem] font-semibold px-[0.6rem] py-[0.2rem] rounded-full"
        style={{
          background: `${conditionColors[item.condition]}22`,
          color: conditionColors[item.condition],
          border: `1px solid ${conditionColors[item.condition]}44`,
        }}
      >
        {item.condition}
      </span>
    </div>

    <h2 class="text-[1.05rem] font-bold text-[#f1f0f7] mb-2 leading-[1.3]">{item.name}</h2>
    <p class="text-[0.85rem] text-[#8b8aa6] leading-[1.5] mb-4 line-clamp-2">{item.description}</p>

    <div class="flex flex-wrap gap-[0.4rem] mb-5">
      {item.tags.map((tag) => (
        <span class="text-[0.72rem] bg-violet-500/[0.12] text-violet-300 border border-violet-500/20 rounded-full px-[0.6rem] py-[0.15rem]">
          #{tag}
        </span>
      ))}
    </div>

    <div class="flex items-center justify-between">
      <div class="card-price text-[1.4rem] font-extrabold text-[#f1f0f7]">
        ${item.price} <span class="text-[0.85rem] font-normal text-[#8b8aa6]">USD</span>
      </div>
      {!item.sold && (
        <button
          class="btn-inquire inline-flex items-center gap-[0.4rem] bg-gradient-to-br from-violet-500 to-violet-700 text-white border-none rounded-[10px] px-4 py-2 text-[0.85rem] font-semibold cursor-pointer transition-[opacity,transform] duration-[200ms] hover:opacity-90 hover:scale-[1.03] active:scale-[0.97] font-sans"
          data-item-name={item.name}
          data-item-price={item.price}
          id={`inquire-btn-${item.id}`}
          aria-label={`Inquire about ${item.name}`}
        >
          ✉️ Inquire
        </button>
      )}
    </div>
  </div>
</article>
