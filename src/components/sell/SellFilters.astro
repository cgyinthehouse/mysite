---
interface Props {
  categories: string[];
}
const { categories } = Astro.props;
---
<div class="max-w-[1100px] mx-auto mt-12 px-[1.2rem] sm:px-8">
  <div class="flex flex-col items-start gap-4 sm:flex-row sm:items-center sm:justify-between mb-6">
    <div class="flex items-center gap-6 flex-wrap">
      <span class="text-[0.85rem] text-[#8b8aa6] font-medium">Filter by category:</span>
      <div class="flex gap-2 flex-wrap" id="category-pills">
        {categories.map((cat) => (
          <button
            class={`pill px-[1.1rem] py-[0.45rem] rounded-full border border-white/[0.08] bg-[#242433] text-[#8b8aa6] text-[0.85rem] font-medium cursor-pointer transition-all hover:border-violet-500 hover:text-violet-300 [&.active]:bg-violet-500 [&.active]:border-violet-500 [&.active]:text-white ${cat === 'All' ? 'active' : ''}`}
            data-category={cat}
            id={`pill-${cat.toLowerCase().replace(/\s+/g, '-')}`}
          >
            {cat}
          </button>
        ))}
      </div>
    </div>
    <div class="flex items-center gap-[0.6rem] bg-[#242433] border border-white/[0.08] rounded-full px-5 py-2 transition-colors focus-within:border-violet-500 w-full sm:w-auto">
      <svg width="16" height="16" fill="none" stroke="#8b8aa6" stroke-width="2" viewBox="0 0 24 24">
        <circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/>
      </svg>
      <input
        type="text"
        id="search-input"
        placeholder="Search items…"
        aria-label="Search marketplace items"
        class="bg-transparent border-none outline-none text-[#f1f0f7] text-[0.9rem] w-[140px] sm:w-[200px] placeholder:text-[#8b8aa6]"
      />
    </div>
  </div>
</div>
