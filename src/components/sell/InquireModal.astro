---
---
<div
  class="modal-overlay fixed inset-0 bg-black/75 backdrop-blur-[8px] z-[200] flex items-center justify-center p-6 opacity-0 pointer-events-none transition-opacity duration-[250ms] [&.open]:opacity-100 [&.open]:pointer-events-auto"
  id="modal-overlay"
  role="dialog"
  aria-modal="true"
  aria-labelledby="modal-title"
>
  <div class="modal bg-[#17171e] border border-white/[0.08] rounded-[16px] p-8 w-full max-w-[480px] relative translate-y-5 transition-transform duration-[250ms] shadow-[0_8px_32px_rgba(0,0,0,0.4)] [.open_&]:translate-y-0">
    <button
      class="absolute top-4 right-4 bg-[#242433] border-none text-[#8b8aa6] w-8 h-8 rounded-lg cursor-pointer text-[1.1rem] flex items-center justify-center transition-colors hover:text-[#f1f0f7]"
      id="modal-close-btn"
      aria-label="Close modal"
    >✕</button>

    <h2 class="text-[1.3rem] font-bold mb-[0.4rem] text-[#f1f0f7]" id="modal-title">Interested? Let's talk!</h2>
    <p class="text-violet-300 text-[0.9rem] mb-6 font-medium" id="modal-item-name"></p>

    <form id="inquire-form" novalidate>
      <div class="mb-4">
        <label for="form-name" class="block text-[0.85rem] font-medium text-[#8b8aa6] mb-[0.4rem]">Your name</label>
        <input
          type="text" id="form-name" name="name" placeholder="e.g. Alex" required
          class="w-full bg-[#242433] border border-white/[0.08] rounded-[10px] px-4 py-[0.7rem] text-[#f1f0f7] text-[0.9rem] outline-none transition-colors focus:border-violet-500"
        />
      </div>
      <div class="mb-4">
        <label for="form-email" class="block text-[0.85rem] font-medium text-[#8b8aa6] mb-[0.4rem]">Email address</label>
        <input
          type="email" id="form-email" name="email" placeholder="you@example.com" required
          class="w-full bg-[#242433] border border-white/[0.08] rounded-[10px] px-4 py-[0.7rem] text-[#f1f0f7] text-[0.9rem] outline-none transition-colors focus:border-violet-500"
        />
      </div>
      <div class="mb-4">
        <label for="form-message" class="block text-[0.85rem] font-medium text-[#8b8aa6] mb-[0.4rem]">Message (optional)</label>
        <textarea
          id="form-message" name="message" placeholder="Any questions about the item?"
          class="w-full bg-[#242433] border border-white/[0.08] rounded-[10px] px-4 py-[0.7rem] text-[#f1f0f7] text-[0.9rem] outline-none transition-colors focus:border-violet-500 resize-y min-h-[90px]"
        ></textarea>
      </div>
      <button
        type="submit"
        class="btn-submit w-full bg-gradient-to-br from-violet-500 to-violet-700 text-white border-none rounded-[10px] py-[0.8rem] text-base font-bold cursor-pointer font-sans transition-opacity hover:opacity-90 mt-2"
        id="form-submit-btn"
      >
        Send Inquiry 🚀
      </button>
    </form>
  </div>
</div>
