---
interface Props {
  dateString: string;
}

const { dateString } = Astro.props;
const date = new Date(dateString);

// Format as 'January 1, 2020' using UTC to avoid timezone drift issues during builds
const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'UTC',
});
---

<time datetime={dateString}>{formattedDate}</time>
