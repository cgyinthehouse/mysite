---
import "../styles/global.css"
import Navbar from "../components/Navbar.astro"
import { Icon } from "astro-icon/components"

const {
  title,
  description = "kent chen's personal website",
  home = false,
  currentPage = ""
} = Astro.props

const name = "Kent"
const siteTitle = "Kent Strong AF"
const displayTitle = title ? `${title} | ${siteTitle}` : siteTitle
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="description" content={description} />
    <title>{displayTitle}</title>

    {/* Open Graph */}
    <meta property="og:title" content={displayTitle} />
    <meta property="og:description" content={description} />
    <meta
      property="og:image"
      content={`https://og-image.vercel.app/${encodeURI(siteTitle)}.png?theme=light&md=0&fontSize=75px&images=https%3A%2F%2Fassets.vercel.com%2Fimage%2Fupload%2Ffront%2Fassets%2Fdesign%2Fnextjs-black-logo.svg`}
    />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body>
    <Navbar currentPage={currentPage} />
    <div class="max-w-xl py-0 px-4 ">
      <header class="flex flex-col items-center">
        {
          home ? (
            <>
              <img
                src="/images/profile.jpg"
                class="rounded-full"
                height={144}
                width={144}
                alt=""
              />
              <h1 class="text-4xl leading-tight font-bold tracking-tighter my-4">
                {name}
              </h1>
            </>
          ) : (
            <>
              <a href="/">
                <img
                  src="/images/profile.jpg"
                  class="rounded-full"
                  height={108}
                  width={108}
                  alt=""
                />
              </a>
              <h2 class="text-2xl mt-4 font-bold">{name}</h2>
            </>
          )
        }
      </header>
      <main>
        <slot />
      </main>
      {
        !home && (
          <div class="mb-8">
            <a
              href="/"
              class="inline-flex items-center gap-2 text-sm font-semibold text-slate-500 hover:text-violet-600 transition-colors duration-200 !no-underline group"
            >
              <Icon
                name="lucide:arrow-left"
                class="w-4 h-4 transition-transform group-hover:-translate-x-1"
              />
              <span>Back to Home</span>
            </a>
          </div>
        )
      }
    </div>
  </body>
</html>
